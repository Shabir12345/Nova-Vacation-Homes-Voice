# Application
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# LLM (Claude via Anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here


# Our database (call logs, intake messages, service requests, FAQs)
# Note: pg requires postgresql:// (or postgres://) — NOT jdbc:postgresql://
# URL-encode special characters in the password (@ → %40, # → %23)
DATABASE_URL=postgresql://nova_callcenter:URL_ENCODED_PASSWORD@HOST:5432/nova_callcenter

# Client's existing database (pms schema — Guesty PMS via FDW)
CLIENT_DATABASE_URL=postgresql://nova_callcenter:URL_ENCODED_PASSWORD@HOST:5432/nova_callcenter
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# Redis (for session state and caching)
REDIS_URL=redis://localhost:6379

# Voice API (Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ConversationRelay — Twilio's managed voice orchestration (STT/TTS/turn detection).
# Public WSS URL Twilio dials into. Dev: ngrok (e.g. wss://abc123.ngrok.io/voice/relay).
# Prod: your deployed hostname. Leave blank to auto-derive from request.hostname.
PUBLIC_WSS_URL=

# ConversationRelay TTS / STT providers
CR_TTS_PROVIDER=ElevenLabs
CR_TRANSCRIPTION_PROVIDER=Deepgram
CR_SPEECH_MODEL=nova-3-general

# ElevenLabs voice IDs per language. Defaults are warm conversational voices —
# replace with your branded clone or any voice from elevenlabs.io/voice-library
CR_VOICE_EN=FGY2WhTYpPnrIDTdsKH5
CR_VOICE_ES=Nh2zY9kknu6z4pZy6FhD
CR_VOICE_PT=cyD08lEy76q03ER1jZ7y

# Tuning — leave defaults unless you know why you're changing them
CR_INTERRUPT_SENSITIVITY=high
CR_EOT_THRESHOLD=0.8

# ElevenLabs voice tuning (appended to voice ID as VOICE_ID-SPEED_STABILITY_SIMILARITY)
# Defaults follow ElevenLabs' conversational guidance for receptionist-style use:
#   speed 1.0       — natural pace; 0.95 sounds calmer, 1.05 more upbeat
#   stability 0.5   — "creative" range, gives prosodic variation; >0.7 is monotone
#   similarity 0.75 — default; higher boosts artifacts
CR_VOICE_SPEED=1.0
CR_VOICE_STABILITY=0.5
CR_VOICE_SIMILARITY=0.75

# Optional: Payment Gateway (if needed for booking processing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...

# Staff notifications (Slack)
# Create at: https://api.slack.com/apps → Your App → Incoming Webhooks
# Leave blank to disable (agent still works — notifications are silent no-ops)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Monitoring & Logging
SENTRY_DSN=https://...

# Feature Flags
ENABLE_ESCALATION=true
ENABLE_PAYMENT_PROCESSING=false
ENABLE_BOOKING_CONFIRMATION_EMAIL=true
