# Application
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# LLM (Claude via Anthropic)
ANTHROPIC_API_KEY=your_key_here

# Our database (call logs, intake messages, service requests, FAQs)
DATABASE_URL=postgresql://user:password@localhost:5432/nova_vacation_homes

# Client's existing database (read-only access for property/reservation lookups)
CLIENT_DATABASE_URL=postgresql://readonly_user:password@client-host:5432/client_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nova_vacation_homes
DB_USER=postgres
DB_PASSWORD=password

# Redis (for session state and caching)
REDIS_URL=redis://localhost:6379

# Voice API (Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Optional: Payment Gateway (if needed for booking processing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...

# Monitoring & Logging
SENTRY_DSN=https://...

# Feature Flags
ENABLE_ESCALATION=true
ENABLE_PAYMENT_PROCESSING=false
ENABLE_BOOKING_CONFIRMATION_EMAIL=true
